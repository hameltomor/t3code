# Minimal local example for dashboard/provider env wiring.
# This file is intentionally not exhaustive for every XBE environment variable.

# Enable cloud-account dashboard surfaces.
XBECODE_DASHBOARD_CLOUD_SYNC=1

# OpenAI organization sync is supported when you have an admin key.
XBECODE_DASHBOARD_OPENAI_ACCOUNT_SYNC=0
# XBECODE_OPENAI_ADMIN_KEY=
# XBECODE_OPENAI_ORGANIZATION_ID=
# XBECODE_OPENAI_ORGANIZATION_NAME=

# Claude Code Max subscription sync is not implemented in the current build.
# There is no Anthropic/Claude Max env var consumed by the dashboard yet.
# Claude usage/limits in the dashboard still require a dedicated adapter.
